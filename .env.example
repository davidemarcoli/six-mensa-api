# Server configuration
PORT=3000
GEMINI_API_KEY=your_api_key_here

# Feature flags
ENABLE_IMAGE_GENERATION=false
ENABLE_MENU_TRANSLATION=true
ENABLE_AUTO_UPDATE=true
ENABLE_PDF_SCRAPING=true
AUTO_UPDATE_INTERVAL_MINUTES=60

# Menu processor: "ai" (default), "regex" (fallback), or "ai-with-fallback"
MENU_PROCESSOR=ai

# Advanced configuration
IMAGE_GENERATION_DELAY=20000
SIX_MENSA_BASE_URL=https://www.betriebsrestaurants-migros.ch
AI_MODEL=gemini-2.0-flash
IMAGE_AI_MODEL=gemini-2.0-flash-preview-image-generation